{
  "expo": {
    "name": "Hermes",
    "slug": "hermes-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0d1117"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hermes.mobile"
    },
    "android": {
      "package": "com.hermes.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0d1117"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
