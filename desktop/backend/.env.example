PORT=3001
SESSION_SECRET=your-super-secret-session-key-change-this

# Anthropic Claude API (required for AI suggestions)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Gmail OAuth (optional - for Gmail accounts)
# Create at https://console.cloud.google.com/apis/credentials
# Enable Gmail API and create OAuth 2.0 credentials
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Outlook / Microsoft OAuth (optional - for Outlook/Hotmail accounts)
# Create at https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Register app with Mail.ReadWrite and Mail.Send permissions
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret

# NOTE: For Gmail without OAuth, use IMAP with an App Password:
# 1. Enable 2FA on your Google account
# 2. Go to Google Account > Security > App passwords
# 3. Create an app password and use it when adding IMAP account
# IMAP Host: imap.gmail.com, Port: 993
# SMTP Host: smtp.gmail.com, Port: 587
